# Database (matches docker-compose.yml local defaults)
DATABASE_URL="postgresql://content_studio:content_studio@localhost:5433/content_studio"

# Auth — change in production
AUTH_SECRET="generate-a-long-random-string-at-least-32-chars"

# Seed admin user (used by `npm run db:seed`)
SEED_ADMIN_EMAIL="admin@contentstudio.local"
SEED_ADMIN_PASSWORD="changeme123"
SEED_ADMIN_NAME="Studio Admin"
SEED_TALENT_NAME="Talent"
# E.164 without + — applied by npm run db:seed to the default talent profile
SEED_WHATSAPP_PHONE=""

# Local file storage (dev default)
UPLOAD_DIR="./uploads"
PUBLIC_BASE_URL="http://localhost:3010"

# Optional: AI prompt enhancement (falls back to template if unset)
OPENAI_API_KEY=""

# Optional: Higgsfield auto-generation (Phase A)
# Get keys from https://cloud.higgsfield.ai — format KEY_ID:KEY_SECRET
HIGGSFIELD_CREDENTIALS=""

# Optional: daily cron trigger — POST /api/cron/generate with Authorization: Bearer <secret>
CRON_SECRET=""

# Optional: WhatsApp review notifications (Meta Cloud API)
# Setup: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
#
# 1. Meta Developer Console → Your App → WhatsApp → API Setup
# 2. WHATSAPP_ACCESS_TOKEN — "Temporary" token (dev) or System User token (prod)
# 3. WHATSAPP_PHONE_NUMBER_ID — shown under "From" on API Setup (not the phone number itself)
# 4. Add your phone as a test recipient in API Setup while app is in Development mode
#
# Dev quick test: leave WHATSAPP_REVIEW_TEMPLATE_NAME empty, message your business number
# from WhatsApp first, then use Settings → WhatsApp → Send test ping within 24 hours.
#
# Production: create an approved template in WhatsApp Manager, e.g.:
#   Name: content_review_ready  Language: English
#   Body: Hi! New content for {{1}} is ready: {{2}}. Review: {{3}}
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_REVIEW_TEMPLATE_NAME=""
WHATSAPP_TEMPLATE_LANGUAGE="en"

# For image-to-video with local photos, Higgsfield must reach your files.
# Use ngrok or a deployed URL instead of localhost for full video generation:
# PUBLIC_BASE_URL="https://your-ngrok-url.ngrok.io"

# Optional: Social publishing (Phase 2)
META_APP_ID=""
META_APP_SECRET=""
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
